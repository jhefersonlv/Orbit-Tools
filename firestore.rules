rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ───────────────────────────────────────────────────────────
       ORBIT TOOLS — Firestore Security Rules
       WordVirtua · 2026

       Modelo multi-tenant:
         users/{uid}/...  → dono ou membro de equipe autorizado
         teamByEmail/{email} → mapeamento email → uid do dono
    ─────────────────────────────────────────────────────────────── */

    /* ── Bloqueia tudo por padrão ──────────────────────────────── */
    match /{document=**} {
      allow read, write: if false;
    }

    /* ── Helpers ────────────────────────────────────────────────── */

    function isAdmin() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null && (u.isAdmin == true || u.IsAdmin == true);
    }

    /* Retorna true se o usuário logado é membro autorizado da equipe do dono (uid) */
    function isTeamMemberOf(uid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/teamByEmail/$(request.auth.token.email))
        && uid in get(/databases/$(database)/documents/teamByEmail/$(request.auth.token.email)).data.ownerUids;
    }

    /* ── Dados do próprio usuário ──────────────────────────────── */
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin() || isTeamMemberOf(uid));
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin() || isTeamMemberOf(uid));

      /* ── CRM / Clientes (SSOT) ──────────────────────────────── */
      match /customers/{customerId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));

        match /history/{entryId} {
          allow read:   if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
          allow create: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
          allow update, delete: if false;
        }

        match /billingHistory/{entryId} {
          allow read:   if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
          allow create: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
          allow update, delete: if false;
        }
      }

      /* ── Planos/Templates ───────────────────────────────────── */
      match /planTemplates/{templateId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      }

      /* ── Agendamentos ──────────────────────────────────────────── */
      match /sched_bookings/{bookingId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
        allow read:   if true;
        allow create: if (request.resource.data.source == 'client'
                          || request.resource.data.source == 'client_area')
                      && request.resource.data.keys().hasAll(['clientName', 'date', 'time', 'status']);
        allow update: if request.auth != null
                      && uid == 'pjk70Jv4anW2ve4aWFdb8dqCpSv2'
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['creditDeducted','updatedAt']);
        allow update: if request.auth != null
                      && uid == 'pjk70Jv4anW2ve4aWFdb8dqCpSv2'
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['renewalRequest','updatedAt']);
      }

      match /sched_services/{serviceId} {
        allow read:  if true;
        allow write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      }

      match /sched_days/{dayId} {
        allow read:  if true;
        allow write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      }

      match /sched_config/{docId} {
        allow read:  if true;
        allow write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      }

      /* ── Disparo Templates ──────────────────────────────────── */
      match /disparo_templates/{tmplId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      }

      /* ── Calculadoras (pessoal — não compartilhado) ─────────── */
      match /km_history/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /clt_history/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      /* ── disparo_contacts (legado) ──────────────────────────── */
      match /disparo_contacts/{contactId} {
        allow read:  if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
        allow write: if false;
      }
    }

    /* ── Kanban de Tarefas ─────────────────────────────────────── */
    match /kanban/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
    }

    /* ── Log de Atividades do Kanban ──────────────────────────── */
    match /kanbanActivity/{uid}/entries/{entryId} {
      allow read, delete: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      allow create:       if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      allow update:       if false;
    }

    /* ── Mapeamento de equipe por e-mail ──────────────────────── */
    match /teamByEmail/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if request.auth != null;
    }
  }
}
